{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Example Config",
  "description": "Example config schema for a Platypus service.",
  "type": "object",
  "required": ["items"],
  "additionalProperties": false,
  "properties": {
    "items": {
      "description": "List of items to provision.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "mode"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "description": "Unique name for the item.",
            "type": "string",
            "examples": ["alpha", "beta"]
          },
          "mode": {
            "description": "Operating mode configuration.",
            "type": "object",
            "required": ["type"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "description": "Mode type.",
                "enum": ["active", "passive", "standby"]
              },
              "settings": {
                "description": "Mode-specific settings.",
                "type": "object",
                "required": [],
                "additionalProperties": false,
                "properties": {
                  "timeout": {
                    "description": "Timeout in seconds.",
                    "type": "integer"
                  },
                  "retries": {
                    "description": "Number of retries.",
                    "type": "integer"
                  }
                }
              }
            }
          },
          "count": {
            "description": "Number of units to provision. Omit to provision one.",
            "type": "integer"
          },
          "enabled": {
            "description": "Whether the item is active. Omit to enable.",
            "type": "boolean"
          }
        }
      }
    }
  }
}
